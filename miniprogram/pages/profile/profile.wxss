/* pages/profile/profile.wxss */
.profile-page { padding-bottom: 40rpx; }

.avatar-section {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 0 24rpx;
}
.avatar-lg {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: #f0f0f0; border: 6rpx solid #1aad19;
}
.role-tag { margin-top: 16rpx; }

.info-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 0; border-bottom: 1rpx solid #f7f7f7;
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 28rpx; color: #999; flex-shrink: 0; }
.info-value { font-size: 28rpx; color: #333; text-align: right; }

.card-title {
  font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; display: block;
}

.group-options { display: flex; flex-wrap: wrap; gap: 20rpx; }
.group-option {
  padding: 20rpx 40rpx; border-radius: 12rpx;
  background: #f7f7f7; border: 2rpx solid #f7f7f7;
  font-size: 28rpx; color: #666;
}
.group-option.active {
  background: #e8f5e9; border-color: #1aad19; color: #1aad19; font-weight: 600;
}

.btn-area { padding: 24rpx; }
.btn-outline { margin-top: 20rpx; }

/* 城市选择触发器 */
.city-trigger {
  display: flex; align-items: center; justify-content: space-between;
}
.city-trigger .placeholder { color: #bbb; }
.city-arrow { color: #bbb; font-size: 32rpx; margin-left: 12rpx; }
