<!-- pages/profile/profile.wxml - 个人资料页 -->
<view class="profile-page">
  <!-- 头像 -->
  <view class="avatar-section">
    <image class="avatar-lg" src="{{userInfo.avatarUrl || '/imgs/back.svg'}}" mode="aspectFill" />
    <text class="role-tag">
      <text class="tag tag-green" wx:if="{{userInfo.role === 'super_admin'}}">超管</text>
      <text class="tag tag-blue" wx:elif="{{userInfo.role === 'admin'}}">管理员</text>
      <text class="tag tag-gray" wx:else>用户</text>
    </text>
  </view>

  <block wx:if="{{!editing}}">
    <!-- 查看模式 -->
    <view class="card">
      <view class="info-row"><text class="info-label">姓名</text><text class="info-value">{{userInfo.realName || '-'}}</text></view>
      <view class="info-row"><text class="info-label">昵称</text><text class="info-value">{{userInfo.nickName || '-'}}</text></view>
      <view class="info-row"><text class="info-label">手机号</text><text class="info-value">{{userInfo.phoneNumber || '-'}}</text></view>
      <view class="info-row"><text class="info-label">微信号</text><text class="info-value">{{userInfo.wechatId || '-'}}</text></view>
      <view class="info-row"><text class="info-label">城市</text><text class="info-value">{{userInfo.city || '-'}}</text></view>
      <view class="info-row"><text class="info-label">所属群</text><text class="info-value">{{groupName}}</text></view>
      <view class="info-row"><text class="info-label">状态</text>
        <text class="tag tag-green" wx:if="{{userInfo.status === 'approved'}}">已通过</text>
        <text class="tag tag-orange" wx:elif="{{userInfo.status === 'pending'}}">待审批</text>
        <text class="tag tag-red" wx:else>已拒绝</text>
      </view>
    </view>
    <view class="btn-area">
      <button class="btn-primary" bindtap="onEdit">编辑资料</button>
    </view>
  </block>

  <block wx:else>
    <!-- 编辑模式 -->
    <view class="card">
      <view class="form-group">
        <text class="form-label">姓名 *</text>
        <input class="form-input" value="{{userInfo.realName}}" data-field="realName" bindinput="onInput" />
      </view>
      <view class="form-group">
        <text class="form-label">昵称</text>
        <input class="form-input" value="{{userInfo.nickName}}" data-field="nickName" bindinput="onInput" />
      </view>
      <view class="form-group">
        <text class="form-label">手机号 *</text>
        <input class="form-input" type="number" value="{{userInfo.phoneNumber}}" data-field="phoneNumber" bindinput="onInput" />
      </view>
      <view class="form-group">
        <text class="form-label">微信号</text>
        <input class="form-input" value="{{userInfo.wechatId}}" data-field="wechatId" bindinput="onInput" />
      </view>
      <view class="form-group">
        <text class="form-label">城市</text>
        <input class="form-input" value="{{userInfo.city}}" data-field="city" bindinput="onInput" />
      </view>
    </view>

    <!-- 选择群组 -->
    <view class="card">
      <text class="card-title">选择所属群</text>
      <view class="group-options">
        <view class="group-option {{selectedGroupId === '' ? 'active' : ''}}" data-id="" bindtap="onSelectGroup">
          <text>未加入</text>
        </view>
        <view wx:for="{{groups}}" wx:key="_id"
              class="group-option {{selectedGroupId === item._id ? 'active' : ''}}"
              data-id="{{item._id}}" bindtap="onSelectGroup">
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <view class="btn-area">
      <button class="btn-primary" bindtap="onSave">保存</button>
      <button class="btn-outline" bindtap="onCancel" style="margin-top:20rpx;">取消</button>
    </view>
  </block>
</view>
