/* pages/super-admin/manage.wxss */
.section-title {
  font-size: 30rpx; font-weight: 600; padding: 32rpx 24rpx 12rpx;
}

.admin-card { padding: 24rpx 28rpx; }
.admin-header { display: flex; align-items: flex-start; }
.admin-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: #f0f0f0; flex-shrink: 0;
}
.admin-info { flex: 1; margin-left: 20rpx; }
.admin-name { font-size: 28rpx; font-weight: 600; display: block; }
.admin-date { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.admin-perms { display: flex; gap: 8rpx; margin-top: 8rpx; }
.admin-actions { display: flex; justify-content: flex-end; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; }

.btn-revoke {
  background: #fff; color: #ff4d4f; border: 2rpx solid #ff4d4f;
  border-radius: 8rpx; padding: 10rpx 24rpx; font-size: 24rpx;
}
.btn-area { padding: 24rpx; }

/* 弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
}
.modal-box {
  position: fixed; top: 15%; left: 32rpx; right: 32rpx; bottom: 40rpx;
  background: #fff; border-radius: 20rpx; padding: 32rpx;
  z-index: 101; overflow-y: auto;
}
.modal-title { font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 24rpx; text-align: center; }

.user-picker { max-height: 300rpx; border: 1rpx solid #eee; border-radius: 12rpx; padding: 8rpx; }
.picker-item {
  padding: 20rpx 16rpx; border-radius: 8rpx; font-size: 26rpx;
  border-bottom: 1rpx solid #f7f7f7;
}
.picker-item:last-child { border-bottom: none; }
.picker-item.active { background: #e8f5e9; color: #1aad19; font-weight: 600; }

.perm-options { display: flex; gap: 16rpx; }
.perm-option {
  flex: 1; padding: 20rpx; border-radius: 12rpx;
  background: #f7f7f7; border: 2rpx solid #f7f7f7;
  text-align: center; font-size: 26rpx;
}
.perm-option.active { background: #e8f5e9; border-color: #1aad19; }

.modal-actions { display: flex; gap: 20rpx; margin-top: 32rpx; }
