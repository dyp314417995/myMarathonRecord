/* pages/points/admin.wxss */
.tabs { display: flex; background: #fff; border-bottom: 1rpx solid #eee; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #999; }
.tab.active { color: #1aad19; font-weight: 600; border-bottom: 4rpx solid #1aad19; }

.sub-tabs { display: flex; background: #fafafa; border-bottom: 1rpx solid #eee; }
.sub-tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: #999; }
.sub-tab.active { color: #1aad19; font-weight: 600; border-bottom: 3rpx solid #1aad19; }

.rule-card { padding: 20rpx 28rpx; margin: 12rpx; }
.rule-row { display: flex; justify-content: space-between; align-items: center; }
.rule-name { font-size: 28rpx; font-weight: 600; display: block; }
.rule-meta { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.rule-status { font-size: 26rpx; padding: 8rpx 20rpx; border-radius: 8rpx; }
.rule-status.on { background: #e8f5e9; color: #1aad19; }
.rule-status.off { background: #f5f5f5; color: #999; }

.review-card { padding: 20rpx 28rpx; margin: 12rpx; }
.empty-tight { padding: 24rpx; text-align: center; font-size: 24rpx; color: #bbb; }
.req-header { display: flex; justify-content: space-between; align-items: center; }
.req-name { font-size: 28rpx; font-weight: 600; }
.req-cat { font-size: 26rpx; color: #1aad19; margin-top: 8rpx; display: block; }
.req-desc { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.req-id { font-size: 22rpx; color: #ccc; display: block; }
.req-debug { font-size: 18rpx; color: #1aad19; display: block; word-break: break-all; }
.req-time { font-size: 22rpx; color: #bbb; margin-top: 2rpx; display: block; }
.req-imgs { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 12rpx; }
.req-img { width: 160rpx; height: 160rpx; border-radius: 8rpx; border: 2rpx solid #eee; }
.req-actions { display: flex; gap: 16rpx; margin-top: 16rpx; justify-content: flex-end; }
.btn-approve { background: #1aad19; color: #fff; border: none; border-radius: 10rpx; padding: 14rpx 32rpx; font-size: 26rpx; }
.btn-reject { background: #fff; color: #ff4d4f; border: 2rpx solid #ff4d4f; border-radius: 10rpx; padding: 14rpx 32rpx; font-size: 26rpx; }

/* 扣减表单 */
.user-trigger { display: flex; align-items: center; }
.user-trigger .placeholder { color: #bbb; }

/* 用户选择弹窗 */
.modal-mask { position: fixed; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.5); z-index:100; }
.modal-box { position: fixed; top: 15%; left: 32rpx; right: 32rpx; bottom: 20%; background: #fff; border-radius: 20rpx; padding: 32rpx; z-index:101; overflow:hidden; display:flex; flex-direction:column; }
.modal-title { font-size: 32rpx; font-weight: 600; text-align: center; margin-bottom: 24rpx; }
.user-list { flex:1; margin-top:16rpx; }
.picker-item { padding: 20rpx 16rpx; border-bottom: 1rpx solid #f7f7f7; font-size: 26rpx; display: flex; align-items: center; gap: 12rpx; }
.picker-check { font-size: 28rpx; width: 40rpx; }

.img-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 8rpx; }
.img-item { width: 120rpx; height: 120rpx; border-radius: 12rpx; overflow: hidden; position: relative; background: #f7f7f7; }
.img-pic { width: 100%; height: 100%; }
.img-remove { position: absolute; top: 4rpx; right: 4rpx; width: 36rpx; height: 36rpx; background: rgba(0,0,0,0.5); border-radius: 50%; color: #fff; text-align: center; line-height: 36rpx; font-size: 24rpx; }
.img-add { display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #ccc; border: 2rpx dashed #eee; }

.load-more { text-align: center; padding: 24rpx; font-size: 26rpx; color: #1aad19; }

.req-tags { display: flex; flex-wrap: wrap; gap: 6rpx; margin-top: 4rpx; }
.race-tag { font-size: 20rpx; color: #1aad19; background: #e8f5e9; padding: 2rpx 10rpx; border-radius: 6rpx; }

/* 赛事管理 */
.race-card { padding: 20rpx 28rpx; margin: 8rpx 12rpx; display: flex; justify-content: space-between; align-items: center; }
.race-info { flex: 1; }
.race-name { font-size: 28rpx; font-weight: 600; display: block; }
.race-meta { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.race-actions { display: flex; gap: 16rpx; }
.act { font-size: 32rpx; padding: 8rpx; }
.act.del { color: #ff4d4f; }
