/* pages/points/index.wxss */
.points-page { padding-bottom: 40rpx; }

.balance-card {
  background: linear-gradient(135deg, #1aad19, #0d8c0d);
  padding: 48rpx 32rpx; text-align: center;
}
.balance-label { font-size: 26rpx; color: rgba(255,255,255,0.7); display: block; }
.balance-num { font-size: 72rpx; font-weight: 700; color: #fff; }
.balance-unit { font-size: 28rpx; color: rgba(255,255,255,0.7); margin-left: 8rpx; }
.expiring-tip {
  margin-top: 16rpx; padding: 12rpx 24rpx; border-radius: 12rpx;
  background: rgba(255,152,0,0.9); color: #fff; font-size: 24rpx;
  display: inline-block;
}

.action-row { display: flex; padding: 24rpx; gap: 24rpx; }
.action-row .btn-primary { flex: 1; }
.admin-entry {
  background: #f5f5f5; border-radius: 12rpx; padding: 24rpx 0;
  text-align: center; font-size: 26rpx; color: #1aad19; width: 180rpx;
}

.section-title {
  font-size: 30rpx; font-weight: 600; padding: 24rpx 24rpx 8rpx;
}

.record-card { padding: 20rpx 28rpx; margin: 8rpx 12rpx; }
.record-row { display: flex; justify-content: space-between; align-items: flex-start; }
.record-info { flex: 1; }
.record-cat { font-size: 28rpx; font-weight: 600; display: block; }
.record-desc { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.record-date { font-size: 22rpx; color: #bbb; margin-top: 6rpx; display: block; }
.record-points { text-align: right; }
.record-points .earn { font-size: 34rpx; font-weight: 700; color: #1aad19; display: block; }
.record-points .use { font-size: 34rpx; font-weight: 700; color: #ff4d4f; display: block; }

/* 规则 */
.rule-row { display: flex; justify-content: space-between; align-items: center; }
.rule-cat { font-size: 28rpx; font-weight: 600; }
.rule-detail { font-size: 26rpx; color: #1aad19; }
.rule-desc { font-size: 24rpx; color: #999; margin-top: 6rpx; display: block; }

.withdraw-btn {
  font-size: 22rpx; color: #ff4d4f; padding: 4rpx 12rpx;
  border: 1rpx solid #ff4d4f; border-radius: 6rpx; margin-top: 8rpx; display: inline-block;
}
