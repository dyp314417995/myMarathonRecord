/* pages/points/apply.wxss */
.apply-page { padding-bottom: 40rpx; }
.card-title { font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; display: block; }

.cat-options { display: flex; flex-wrap: wrap; gap: 16rpx; }
.cat-option {
  padding: 20rpx 32rpx; border-radius: 12rpx; background: #f7f7f7;
  border: 2rpx solid #f7f7f7; text-align: center; font-size: 28rpx; color: #666;
}
.cat-option.active { background: #e8f5e9; border-color: #1aad19; color: #1aad19; font-weight: 600; }
.cat-desc { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

.count-tip { margin-top: 16rpx; font-size: 26rpx; color: #ff9800; }
.limit-tip { margin-top: 8rpx; font-size: 26rpx; color: #ff4d4f; font-weight: 600; }

.img-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img-item {
  width: 150rpx; height: 150rpx; border-radius: 12rpx;
  overflow: hidden; position: relative; background: #f7f7f7;
}
.img-item image { width: 100%; height: 100%; }
.img-remove {
  position: absolute; top: 4rpx; right: 4rpx; width: 36rpx; height: 36rpx;
  background: rgba(0,0,0,0.5); border-radius: 50%; color: #fff;
  text-align: center; line-height: 36rpx; font-size: 24rpx;
}
.img-add {
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; color: #ccc; border: 2rpx dashed #eee;
}

.form-textarea { width: 100%; height: 160rpx; background: #f7f7f7; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; box-sizing: border-box; }

.btn-area { padding: 32rpx 24rpx 0; }

.qty-row { display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx; }
.qty-label { font-size: 26rpx; color: #666; }
.qty-stepper { display: flex; align-items: center; gap: 0; background: #f5f5f5; border-radius: 12rpx; overflow: hidden; }
.qty-btn { font-size: 32rpx; padding: 8rpx 28rpx; color: #333; background: #e8e8e8; text-align: center; }
.qty-val { font-size: 28rpx; padding: 8rpx 24rpx; color: #333; background: #fff; min-width: 60rpx; text-align: center; }
.qty-total { font-size: 24rpx; color: #1aad19; font-weight: 600; }
