.page { padding-bottom: 40rpx; }
.banner { width: 100%; height: 360rpx; }
.card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin: 12rpx 16rpx; }
.act-name { font-size: 34rpx; font-weight: 700; color: #333; display: block; }
.act-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; margin-top: 8rpx; display: inline-block; }
.act-status.active { background: #e8f5e9; color: #1aad19; }
.act-status.finished { background: #f5f5f5; color: #999; }
.act-status.cancelled { background: #fff2f0; color: #ff4d4f; }

.info-row { font-size: 26rpx; color: #555; display: block; margin-top: 10rpx; }
.desc { font-size: 26rpx; color: #666; line-height: 1.6; white-space: pre-wrap; }

.card-title { font-size: 28rpx; font-weight: 700; color: #333; margin-bottom: 12rpx; display: block; }
.radio-group { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 12rpx; }
.radio-opt { font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 12rpx; background: #f7f7f7; color: #666; }
.radio-opt.on { background: #e8f5e9; color: #1aad19; }

.btn-area { padding: 24rpx; }
.btn-primary { width: 100%; background: #1aad19; color: #fff; border-radius: 12rpx; padding: 16rpx; font-size: 30rpx; border: none; }
.btn-outline { width: 100%; background: #fff; color: #ff4d4f; border: 2rpx solid #ff4d4f; border-radius: 12rpx; padding: 16rpx; font-size: 30rpx; }
