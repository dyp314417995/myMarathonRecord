<!-- pages/tools/activity/index.wxml -->
<view class="page">
  <view class="tabs">
    <text class="tab {{tab === 'all' ? 'on' : ''}}" bindtap="onTab" data-t="all">所有活动</text>
    <text class="tab {{tab === 'my' ? 'on' : ''}}" bindtap="onTab" data-t="my">我的活动</text>
  </view>

  <view class="list" wx:if="{{tab === 'all'}}">
    <view class="act-card" wx:for="{{activities}}" wx:key="_id" bindtap="onDetail" data-id="{{item._id}}">
      <image wx:if="{{item.images[0]}}" src="{{item.images[0]}}" mode="aspectFill" class="card-img" />
      <view class="card-body">
        <text class="card-name">{{item.name}}</text>
        <text class="card-info">📅 {{item.timeStart}} 📍 {{item.location}}</text>
        <text class="card-count">👥 {{item.regCount || 0}}{{item.maxPeople ? '/' + item.maxPeople : ''}} 人已报名</text>
        <text class="card-fee" wx:if="{{item.fee}}">💰 {{item.fee}}</text>
      </view>
    </view>
    <view wx:if="{{!activities.length}}" class="empty">暂无活动</view>
  </view>

  <view class="list" wx:if="{{tab === 'my'}}">
    <view class="act-card" wx:for="{{myActivities}}" wx:key="_id" bindtap="onDetail" data-id="{{item._id}}">
      <image wx:if="{{item.images[0]}}" src="{{item.images[0]}}" mode="aspectFill" class="card-img" />
      <view class="card-body">
        <text class="card-name">{{item.name}}</text>
        <text class="card-info">📅 {{item.timeStart}} 📍 {{item.location}}</text>
        <text class="card-count">👥 {{item.regCount || 0}} 人已报名</text>
      </view>
    </view>
    <view wx:if="{{!myActivities.length}}" class="empty">还没报名活动</view>
  </view>
</view>
