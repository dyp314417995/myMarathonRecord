<!-- pages/tools/activity/detail.wxml -->
<view class="page" wx:if="{{activity}}">
  <view class="card">
    <text class="act-name">{{activity.name}}</text>
  </view>

  <!-- 按创建顺序：时间、地点、费用、截止、人数 -->
  <view class="card">
    <text class="info-row">📅 {{activity._fmtStart}} ~ {{activity._fmtEnd}}</text>
    <text class="info-row">📍 {{activity.location || '待定'}}</text>
    <text class="info-row">💰 {{activity.fee || '免费'}}</text>
    <text class="info-row">🕐 报名截止：{{activity._fmtDeadline || '--'}}</text>
    <text class="info-row">👥 {{activity.regCount || 0}}{{activity.maxPeople ? '/' + activity.maxPeople : ''}} 人已报名</text>
  </view>

  <!-- 图片 -->
  <view class="card" wx:if="{{activity.images && activity.images.length > 0}}">
    <image wx:for="{{activity.images}}" wx:key="*this" src="{{item}}" mode="aspectFill" class="detail-img" />
  </view>

  <!-- 说明 -->
  <view class="card" wx:if="{{activity.description}}">
    <text class="desc">{{activity.description}}</text>
  </view>

  <!-- 自定义报名表单 -->
  <view class="card" wx:if="{{activity.customFields && activity.customFields.length && activity.status === 'active'}}">
    <text class="card-title">报名信息</text>
    <block wx:if="{{!registered}}">
      <block wx:for="{{activity.customFields}}" wx:key="index" wx:for-item="f">
        <text class="form-label">{{f.label}} {{f.required ? '*' : ''}}</text>
        <input wx:if="{{f.type === 'text' || f.type === 'number'}}" class="form-input" value="{{customValues[f.label]}}" data-k="{{f.label}}" bindinput="onCustomInput" placeholder="请输入" />
        <view wx:if="{{f.type === 'radio'}}" class="radio-group">
          <text class="radio-opt {{customValues[f.label] === o ? 'on' : ''}}" wx:for="{{f.options}}" wx:key="*this" wx:for-item="o" data-k="{{f.label}}" data-v="{{o}}" bindtap="onCustomRadio">{{o}}</text>
        </view>
        <view wx:if="{{f.type === 'checkbox'}}" class="radio-group">
          <text class="radio-opt {{customValues[f.label+'_'+o] ? 'on' : ''}}" wx:for="{{f.options}}" wx:key="*this" wx:for-item="o" data-k="{{f.label}}" data-v="{{o}}" bindtap="onCustomCheck">{{o}}</text>
        </view>
      </block>
    </block>
    <block wx:else>
      <text style="font-size:22rpx;color:#999;">如需修改报名信息，请取消后重新报名</text>
    </block>
  </view>

  <!-- 报名列表（管理员可见） -->
  <view class="card" wx:if="{{isAdmin && regList.length}}">
    <text class="card-title">报名列表 ({{regList.length}}人)</text>
    <view class="reg-item" wx:for="{{regList}}" wx:key="_id">
      <text class="reg-name">{{item.userName}}</text>
      <text class="reg-phone">{{item.userPhone}}</text>
    </view>
  </view>

  <!-- 操作按钮（管理员不显示） -->
  <view class="btn-area" wx:if="{{activity.status === 'active' && !isAdmin}}">
    <button wx:if="{{!registered}}" class="btn-primary" bindtap="onRegister">立即报名</button>
    <button wx:else class="btn-outline" bindtap="onUnregister">取消报名</button>
  </view>
</view>
