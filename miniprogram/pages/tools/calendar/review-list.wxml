<!-- pages/tools/calendar/review-list.wxml -->
<view class="review-list-page">
  <view class="card">
    <text class="page-title">{{eventName}} - 评分详情</text>
    <text class="page-sub" wx:if="{{stats && stats.count > 0}}">综合 {{stats.avgScore}} · {{stats.count}}人参与</text>
    <text class="page-sub" wx:else>暂无评分</text>
  </view>

  <!-- 各维度评分 -->
  <view class="card" wx:if="{{stats && stats.dimensions}}">
    <view class="section-title">各维度平均分</view>
    <view class="dim-row" wx:for="{{stats.dimensions}}" wx:key="name" wx:for-item="val" wx:for-index="dim">
      <text class="dim-label">{{dimLabels[dim] || dim}}</text>
      <view class="dim-bar-wrap"><view class="dim-bar" style="width:{{val*10}}%"></view></view>
      <text class="dim-val">{{val}}</text>
    </view>
  </view>

  <!-- 标签排行 -->
  <view class="card" wx:if="{{topTags.length > 0}}">
    <view class="section-title">🏷 热门标签 TOP {{topTags.length}}</view>
    <view class="tag-row" wx:for="{{topTags}}" wx:key="0" wx:for-item="t" wx:for-index="idx">
      <text class="tag-rank">#{{idx + 1}}</text>
      <text class="tag-name">{{t[0]}}</text>
      <view class="tag-bar-wrap"><view class="tag-bar" style="width:{{t[1]/topTags[0][1]*100}}%"></view></view>
      <text class="tag-count">×{{t[1]}}</text>
    </view>
  </view>
</view>
