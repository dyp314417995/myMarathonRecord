<!-- pages/tools/calendar/detail.wxml -->
<view class="detail-page">
  <!-- 基本信息 -->
  <view class="card">
    <view class="header-row">
      <text class="event-name">{{event.name}}</text>
      <text class="countdown">{{event.countdown}}</text>
    </view>
    <view class="meta-row">
      <text>{{event.city || '未知'}} · {{event.raceTypeName}}<text wx:if="{{event.raceType !== 'trail'}}"> · {{event.raceLevel}}级</text></text>
    </view>
    <view wx:if="{{event.distance}}" class="meta-row">
      <text>距离 {{event.distance}}km<text wx:if="{{event.elevation}}"> · 爬升 {{event.elevation}}m</text></text>
    </view>
    <view wx:if="{{event.certs && (event.certs.itra || event.certs.utmb || event.certs.utmbws)}}" class="meta-row">
      <text>认证：{{event.certs.itra ? 'ITRA ' : ''}}{{event.certs.utmb ? 'UTMB ' : ''}}{{event.certs.utmbws ? 'UTMB世界系列赛' : ''}}</text>
    </view>
    <view wx:if="{{event.website}}" class="link-row" bindtap="onWebsite">
      <text>📎 官网链接（点击复制）</text>
    </view>
    <view wx:if="{{event.scale || event.fee || event.mechanism || event.label || event.payment}}" class="meta-row">
      <text>{{event.label ? event.label + ' · ' : ''}}{{event.scale ? event.scale + ' · ' : ''}}{{event.fee ? event.fee + ' · ' : ''}}{{event.mechanism ? event.mechanism + ' · ' : ''}}{{event.payment ? event.payment : ''}}</text>
    </view>
  </view>

  <!-- 时间轴 -->
  <view class="card" wx:if="{{event.timeline && event.timeline.length > 0}}">
    <view class="section-title"><text>⏱ 赛事时间轴</text></view>
    <view class="timeline">
      <view class="tl-item" wx:for="{{event.timeline}}" wx:key="label" wx:for-item="t">
        <view class="tl-dot">🚩</view>
        <view class="tl-body">
          <text class="tl-label">{{t.label}}</text>
          <text class="tl-date">{{t.date}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 评分概览 -->
  <view class="card" wx:if="{{reviewStats && reviewStats.count > 0}}">
    <view class="section-title" bindtap="onScoreDetail">
      <text>赛事评分</text>
      <text class="arrow">›</text>
    </view>
    <view class="score-overview">
      <view class="overall-score">
        <text class="score-num">{{reviewStats.avgScore}}</text>
        <text class="score-label">综合评分</text>
        <text class="score-count">{{reviewStats.count}}人参与</text>
      </view>
      <view class="dim-scores">
        <view class="dim-row" wx:for="{{reviewStats.dimensions}}" wx:key="name">
          <text class="dim-name">{{''}}</text>
          <view class="dim-bar-wrap"><view class="dim-bar" style="width:{{item*10}}%"></view></view>
          <text class="dim-val">{{item}}</text>
        </view>
      </view>
    </view>
  </view>
  <view class="card" wx:else>
    <text class="no-score">暂无评分</text>
  </view>

  <!-- 热门标签 -->
  <view class="card" wx:if="{{topTags.length > 0}}">
    <view class="section-title"><text>🏷 热门标签</text></view>
    <view class="tag-list">
      <view class="tag-item" wx:for="{{topTags}}" wx:key="0" wx:for-item="t">
        <text class="tag-name">{{t[0]}}</text>
        <text class="tag-count">×{{t[1]}}</text>
      </view>
    </view>
  </view>

  <!-- 我的评价 -->
  <view class="card" wx:if="{{myReview}}">
    <view class="section-title">
      <text>📝 我的评价</text>
      <text class="del-review-btn" data-id="{{myReview._id}}" catchtap="onDelMyReview">🗑 删除</text>
    </view>
    <view class="my-review">
      <view class="my-dim-list">
        <text class="my-dim" wx:for="{{['difficulty','atmosphere','supply','transport','scenery','org','medal','value']}}" wx:key="*this" wx:for-item="k">
          {{k}} {{myReview.scores[k]}}
        </text>
      </view>
      <view wx:if="{{myReview.tags && myReview.tags.length}}" class="req-tags">
        <text class="race-tag" wx:for="{{myReview.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 管理员：所有评价管理 -->
  <view class="card" wx:if="{{isAdmin}}">
    <view class="section-title"><text>🛡 管理评价</text><text class="admin-load" bindtap="onLoadAllReviews">加载</text></view>
    <view wx:if="{{allReviews.length === 0}}" class="empty-tight"><text>点击加载查看所有评价</text></view>
    <view class="review-item" wx:for="{{allReviews}}" wx:key="_id">
      <view class="review-user">
        <text class="reviewer-name">{{item.userName}}</text>
        <text class="review-time">{{item.fmtTime}}</text>
      </view>
      <text class="review-scores">{{item.fmtScores}}</text>
      <view wx:if="{{item.tags && item.tags.length}}" class="req-tags">
        <text class="race-tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
      </view>
      <text class="del-review-btn" data-id="{{item._id}}" catchtap="onDelReview">🗑 删除</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="btn-area">
    <button wx:if="{{myStatus === 'finished' || myReview}}" class="btn-primary" bindtap="onReview">{{myReview ? '✏️ 修改评价' : '⭐ 参与评分'}}</button>
    <button wx:elif="{{isMine && myStatus !== 'finished'}}" class="btn-primary disabled" disabled>需标记"已完赛"后才可评分</button>
  </view>
</view>
