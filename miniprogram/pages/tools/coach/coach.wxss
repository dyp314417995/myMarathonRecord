.coach-page { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }

.chat-body { flex: 1; padding: 24rpx; }

.msg-row { display: flex; margin-bottom: 24rpx; }
.msg-row.user { justify-content: flex-end; }
.msg-row.bot { justify-content: flex-start; }

.msg-bubble {
  max-width: 80%; padding: 20rpx 28rpx; border-radius: 20rpx;
  font-size: 28rpx; line-height: 1.6; white-space: pre-wrap;
}
.msg-row.user .msg-bubble { background: #1aad19; color: #fff; border-bottom-right-radius: 4rpx; }
.msg-row.bot .msg-bubble { background: #fff; color: #333; border-bottom-left-radius: 4rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }

.quick-asks { padding: 16rpx 24rpx; background: #fff; border-top: 1rpx solid #f0f0f0; }
.quick-title { font-size: 24rpx; color: #999; margin-bottom: 12rpx; display: block; }
.quick-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.quick-tag { 
  padding: 12rpx 24rpx; background: #f0f9ff; color: #1aad19;
  border-radius: 40rpx; font-size: 26rpx;
}

.chat-input {
  display: flex; align-items: center; padding: 16rpx 24rpx;
  background: #fff; border-top: 1rpx solid #f0f0f0; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.msg-input { flex: 1; height: 72rpx; background: #f5f5f5; border-radius: 36rpx; padding: 0 28rpx; font-size: 28rpx; }
.send-btn { 
  margin-left: 16rpx; width: 120rpx; height: 72rpx; border-radius: 36rpx;
  background: #1aad19; color: #fff; font-size: 28rpx; line-height: 72rpx;
  padding: 0; text-align: center;
}
.send-btn[disabled] { background: #ccc; }
