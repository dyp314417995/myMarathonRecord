<!-- pages/home/home.wxml - 首页面板 -->
<view class="home-page">
  <!-- 用户信息卡片 -->
  <view class="user-card card">
    <view class="user-info" bindtap="onProfile">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/imgs/back.svg'}}" mode="aspectFill" />
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickName || '未设置'}}</text>
        <view class="user-meta">
          <text class="tag tag-green" wx:if="{{role === 'super_admin'}}">超级管理员</text>
          <text class="tag tag-blue" wx:elif="{{role === 'admin'}}">管理员</text>
          <text class="tag tag-gray" wx:else>普通用户</text>
          <text class="tag tag-orange" wx:if="{{status === 'pending'}}">待审批</text>
        </view>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{groupName}}</text>
        <text class="stat-label">所属群</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{userInfo.city || '未设置'}}</text>
        <text class="stat-label">城市</text>
      </view>
    </view>
  </view>

  <!-- ========== 超管 ========== -->
  <block wx:if="{{role === 'super_admin'}}">
    <view class="section-title">管理</view>
    <view class="menu-grid col2">
      <view class="menu-item card" bindtap="onManageAdmins">
        <text class="menu-icon">👤</text>
        <text class="menu-text">管理员配置</text>
      </view>
      <view class="menu-item card" bindtap="onManageUsers">
        <text class="menu-icon">👥</text>
        <text class="menu-text">用户管理</text>
      </view>
      <view class="menu-item card" bindtap="onManageGroups">
        <text class="menu-icon">🔧</text>
        <text class="menu-text">群组管理</text>
      </view>
      <view class="menu-item card" bindtap="onPointsAdmin">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">积分管理</text>
      </view>
    </view>

    <view class="section-title">我的</view>
    <view class="menu-grid col2">
      <view class="menu-item card" bindtap="onGroups">
        <text class="menu-icon">📋</text>
        <text class="menu-text">跑群列表</text>
      </view>
      <view class="menu-item card" bindtap="onMemberList">
        <text class="menu-icon">🏅</text>
        <text class="menu-text">跑友名录</text>
      </view>
      <view class="menu-item card" bindtap="onPoints">
        <text class="menu-icon">🏃</text>
        <text class="menu-text">我的积分</text>
      </view>
      <view class="menu-item card" bindtap="onRecords">
        <text class="menu-icon">🏁</text>
        <text class="menu-text">跑马记录</text>
      </view>
    </view>
  </block>

  <!-- ========== 管理员 ========== -->
  <block wx:elif="{{role === 'admin'}}">
    <view class="section-title">管理</view>
    <view class="menu-grid col2">
      <view class="menu-item card" bindtap="onManageUsers">
        <text class="menu-icon">👥</text>
        <text class="menu-text">用户管理</text>
      </view>
      <view class="menu-item card" bindtap="onPointsAdmin">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">积分管理</text>
      </view>
    </view>

    <view class="section-title">我的</view>
    <view class="menu-grid col2">
      <view class="menu-item card" bindtap="onGroups">
        <text class="menu-icon">📋</text>
        <text class="menu-text">跑群列表</text>
      </view>
      <view class="menu-item card" bindtap="onMemberList">
        <text class="menu-icon">🏅</text>
        <text class="menu-text">跑友名录</text>
      </view>
      <view class="menu-item card" bindtap="onPoints">
        <text class="menu-icon">🏃</text>
        <text class="menu-text">我的积分</text>
      </view>
      <view class="menu-item card" bindtap="onRecords">
        <text class="menu-icon">🏁</text>
        <text class="menu-text">跑马记录</text>
      </view>
    </view>
  </block>

  <!-- ========== 普通用户 ========== -->
  <block wx:else>
    <view class="section-title">我的</view>
    <view class="menu-grid col2">
      <view class="menu-item card" bindtap="onGroups">
        <text class="menu-icon">📋</text>
        <text class="menu-text">跑群列表</text>
      </view>
      <view class="menu-item card" bindtap="onMemberList">
        <text class="menu-icon">🏅</text>
        <text class="menu-text">跑友名录</text>
      </view>
      <view class="menu-item card" bindtap="onPoints">
        <text class="menu-icon">🏃</text>
        <text class="menu-text">我的积分</text>
      </view>
      <view class="menu-item card" bindtap="onRecords">
        <text class="menu-icon">🏁</text>
        <text class="menu-text">跑马记录</text>
      </view>
    </view>
  </block>

  <!-- ========== 小工具 ========== -->
  <view class="section-title">小工具</view>
  <view class="menu-grid col2">
    <view class="menu-item card disabled">
      <text class="menu-icon">📅</text>
      <text class="menu-text">赛事日历</text>
    </view>
    <view class="menu-item card" bindtap="onAiCoach">
      <text class="menu-icon">💬</text>
      <text class="menu-text">跑步教练</text>
    </view>
    <view class="menu-item card disabled">
      <text class="menu-icon">⏱️</text>
      <text class="menu-text">配速计算器</text>
    </view>
  </view>
</view>
