<!-- pages/groups/index.wxml -->
<view class="groups-page">
  <block wx:for="{{groups}}" wx:key="_id">
    <view class="card group-card">
      <text class="group-name">{{item.name}}</text>
      <text wx:if="{{item.description}}" class="group-desc">{{item.description}}</text>
      <view wx:if="{{item.qrCodeUrl}}" class="qr-section" data-url="{{item.qrCodeUrl}}" bindtap="onPreviewQR">
        <image class="qr-img" src="{{item.qrCodeUrl}}" mode="aspectFit" />
        <text class="qr-tip">点击查看大图并长按识别</text>
      </view>
      <view wx:else class="remark-box">
        <text>{{item.remark || '群已满，请联系管理员邀请加入'}}</text>
      </view>
    </view>
  </block>

  <view wx:if="{{groups.length === 0}}" class="empty-state">
    <text>暂无跑群</text>
  </view>
</view>
