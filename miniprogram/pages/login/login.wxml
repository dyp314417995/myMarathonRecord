<!-- pages/login/login.wxml - 登录注册页 -->
<view class="login-page">
  <!-- 头部 Banner -->
  <view class="header">
    <text class="header-title">我的跑马记录</text>
    <text class="header-sub">欢迎加入，请完善以下信息</text>
  </view>

  <!-- 头像 & 昵称 -->
  <view class="card">
    <view class="avatar-row">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar" src="{{avatarUrl || '/imgs/back.svg'}}" mode="aspectFill" />
        <text class="avatar-tip">点击设置头像</text>
      </button>
    </view>
    <view class="form-group">
      <text class="form-label">微信昵称</text>
      <input class="form-input" type="nickname" placeholder="自动获取或手动输入" value="{{nickName}}" bindinput="onNicknameInput" />
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <text class="card-title">基本信息</text>
    <view class="form-group">
      <text class="form-label">真实姓名 *</text>
      <input class="form-input" placeholder="请输入真实姓名" value="{{realName}}" bindinput="onInput" data-field="realName" />
    </view>
    <view class="form-group">
      <text class="form-label">手机号 *</text>
      <view class="phone-row">
        <input class="form-input phone-input" type="number" placeholder="请输入手机号" value="{{phoneNumber}}" bindinput="onPhoneInput" />
        <button class="phone-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">微信获取</button>
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">微信号</text>
      <input class="form-input" placeholder="微信号（选填）" value="{{wechatId}}" bindinput="onInput" data-field="wechatId" />
    </view>
    <view class="form-group">
      <text class="form-label">所在城市</text>
      <input class="form-input" placeholder="例如：北京、上海" value="{{city}}" bindinput="onInput" data-field="city" />
    </view>
  </view>

  <!-- 选择所属群 -->
  <view class="card">
    <text class="card-title">选择所属群</text>
    <view class="group-options">
      <view class="group-option {{selectedGroupId === '' ? 'active' : ''}}" data-id="" data-name="未加入" bindtap="onSelectGroup">
        <text>未加入</text>
      </view>
      <view wx:for="{{groups}}" wx:key="_id"
            class="group-option {{selectedGroupId === item._id ? 'active' : ''}}"
            data-id="{{item._id}}" data-name="{{item.name}}" bindtap="onSelectGroup">
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="btn-area">
    <button class="btn-primary" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">
      {{selectedGroupId ? '提交申请' : '完成注册'}}
    </button>
    <view class="skip-link" bindtap="onSkip">稍后完善</view>
  </view>
</view>
