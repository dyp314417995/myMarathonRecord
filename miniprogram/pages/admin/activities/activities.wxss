.page { padding: 16rpx; }
.top-bar { padding: 16rpx 0; }
.act-card { background: #fff; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; }
.act-row1 { display: flex; justify-content: space-between; align-items: center; }
.act-name { font-size: 30rpx; font-weight: 700; color: #333; }
.state-tag { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; flex-shrink: 0; }
.state-s1 { background: #e8f5e9; color: #1aad19; }
.state-s2 { background: #e3f2fd; color: #1976d2; }
.state-s3 { background: #fff3e0; color: #ff9800; }
.state-s4 { background: #fff3e0; color: #ff9800; }
.state-s5 { background: #fff2f0; color: #ff4d4f; }
.state-s6 { background: #f5f5f5; color: #999; }
.state-s7 { background: #f5f5f5; color: #ccc; }
.act-info { font-size: 24rpx; color: #888; display: block; margin-top: 6rpx; }
.act-ops { display: flex; gap: 16rpx; margin-top: 12rpx; }
.op-btn { font-size: 22rpx; padding: 4rpx 8rpx; color: #555; }
.op-btn.del { color: #ff4d4f; }

.img-row { display: flex; gap: 12rpx; flex-wrap: wrap; margin-bottom: 12rpx; }
.img-thumb { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.img-add { width: 120rpx; height: 120rpx; border-radius: 8rpx; border: 2rpx dashed #ddd; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #ccc; }

.field-item { display: flex; flex-wrap: wrap; align-items: center; gap: 8rpx; margin-bottom: 8rpx; padding: 8rpx; background: #f9f9f9; border-radius: 8rpx; }
.field-item .btn-row { display: flex; gap: 4rpx; }
.field-item .opt-btn { font-size: 20rpx; padding: 4rpx 10rpx; border-radius: 6rpx; background: #eee; color: #666; }
.field-item .opt-btn.on { background: #e8f5e9; color: #1aad19; }
.field-del { font-size: 28rpx; color: #ff4d4f; padding: 4rpx; }
.add-field { text-align: center; padding: 12rpx; font-size: 24rpx; color: #1aad19; border: 1rpx dashed #1aad19; border-radius: 8rpx; margin: 8rpx 0; }

.reg-item { padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.reg-name { font-size: 28rpx; color: #333; }
.reg-phone { font-size: 22rpx; color: #999; margin-left: 12rpx; }
.reg-fields { margin-top: 4rpx; display: flex; flex-wrap: wrap; gap: 8rpx; }
.reg-f { font-size: 20rpx; color: #666; background: #f5f5f5; padding: 4rpx 8rpx; border-radius: 6rpx; }

.modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; }
.modal-content { background: #fff; border-radius: 16rpx; width: 90vw; max-height: 85vh; padding: 24rpx; }
.modal-title { font-size: 32rpx; font-weight: 700; display: block; margin-bottom: 16rpx; }
.modal-actions { display: flex; gap: 16rpx; margin-top: 20rpx; }
.btn-outline { flex: 1; border: 2rpx solid #ddd; background: #fff; border-radius: 12rpx; padding: 16rpx; }
.btn-primary { flex: 1; background: #1aad19; color: #fff; border-radius: 12rpx; padding: 16rpx; border: none; }
.btn-sm { padding: 12rpx 24rpx; font-size: 26rpx; }
.empty { text-align: center; padding: 80rpx; color: #bbb; font-size: 28rpx; }

.info-row { font-size: 26rpx; color: #555; margin-top: 8rpx; }
.divider { height: 1rpx; background: #eee; margin: 16rpx 0; }
.form-label { font-size: 26rpx; font-weight: 700; color: #333; margin-bottom: 8rpx; display: block; }
