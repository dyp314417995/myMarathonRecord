/* pages/admin/races/races.wxss */
.races-page { padding-bottom: 40rpx; }
.race-card { padding: 20rpx 28rpx; margin: 8rpx 12rpx; display: flex; justify-content: space-between; align-items: center; }
.race-info { flex: 1; }
.race-name { font-size: 28rpx; font-weight: 600; display: block; }
.race-meta { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.race-actions { display: flex; gap: 16rpx; }
.act { font-size: 32rpx; padding: 8rpx; }
.act.del { color: #ff4d4f; }

.review-scroll { max-height: 600rpx; }
.rv-item { padding: 16rpx 0; border-bottom: 1rpx solid #f7f7f7; position: relative; }
.rv-item:last-child { border-bottom: none; }
.rv-user { display: flex; justify-content: space-between; margin-bottom: 4rpx; }
.rv-name { font-size: 26rpx; font-weight: 600; }
.rv-time { font-size: 22rpx; color: #bbb; }
.rv-scores { font-size: 22rpx; color: #666; display: block; }
.rv-del { position: absolute; right: 0; top: 16rpx; font-size: 22rpx; color: #ff4d4f; padding: 4rpx 8rpx; }
.empty-tight { padding: 24rpx; text-align: center; font-size: 24rpx; color: #bbb; }
.req-tags { display: flex; flex-wrap: wrap; gap: 6rpx; margin-top: 4rpx; }
.race-tag { font-size: 20rpx; color: #1aad19; background: #e8f5e9; padding: 2rpx 10rpx; border-radius: 6rpx; }

.form-label { font-size: 26rpx; color: #666; display: block; margin-top: 20rpx; }
.btn-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 8rpx; }
.opt-btn {
  padding: 12rpx 24rpx; border-radius: 8rpx; background: #f7f7f7;
  font-size: 26rpx; color: #666; border: 2rpx solid #f7f7f7;
  flex-shrink: 0;
}
.opt-btn.on { background: #e8f5e9; border-color: #1aad19; color: #1aad19; font-weight: 600; }

.modal-mask { position: fixed; top:0; left:0; right:0; bottom:0; background: rgba(0,0,0,0.5); z-index:100; }
.modal-box { position: fixed; top: 10%; left: 32rpx; right: 32rpx; bottom: 10%; background: #fff; border-radius: 20rpx; padding: 32rpx; z-index:101; overflow-y: auto; }
.modal-header { display: flex; justify-content: space-between; align-items: center; font-size: 32rpx; font-weight: 600; margin-bottom: 16rpx; }
.modal-close { font-size: 36rpx; color: #999; padding: 8rpx; }
.modal-actions { display: flex; gap: 16rpx; }
.modal-actions .btn-primary { flex: 1; }
.modal-actions .btn-outline { flex: 1; }

.form-input { background: #f7f7f7; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; margin-top: 8rpx; }
.date-input { display: flex; align-items: center; }
.placeholder { color: #bbb; }

.paste-trigger { padding: 12rpx 20rpx; margin-top: 8rpx; background: #f0f7ff; border-radius: 12rpx; font-size: 24rpx; color: #1a73e8; border: 2rpx dashed #1a73e8; text-align: center; }
.paste-area { margin-top: 8rpx; }
.paste-input { width: 100%; min-height: 160rpx; background: #f7f7f7; border-radius: 12rpx; padding: 16rpx; font-size: 24rpx; box-sizing: border-box; }
.paste-actions { display: flex; align-items: center; gap: 16rpx; margin-top: 8rpx; }
.paste-close { font-size: 24rpx; color: #999; }

.admin-filter { padding: 8rpx 12rpx; background: #fff; }
.filter-input { background: #f5f5f5; border-radius: 8rpx; padding: 12rpx 16rpx; font-size: 26rpx; margin-bottom: 8rpx; }
.filter-row { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 8rpx; }
.filter-chip { font-size: 22rpx; color: #666; padding: 4rpx 14rpx; border-radius: 12rpx; background: #f5f5f5; flex-shrink: 0; }
.filter-chip.on { background: #e8f5e9; color: #1aad19; font-weight: 600; }

.result-row { display: flex; align-items: center; gap: 8rpx; }
.result-pick { margin-top: 0 !important; flex: 1; text-align: center; }
.result-sep { font-size: 32rpx; color: #666; }
.result-row .form-input { margin-top: 0 !important; }

.confirm-row { display: flex; justify-content: space-between; align-items: center; margin-top: 20rpx; }
.confirm-toggle { font-size: 26rpx; padding: 8rpx 20rpx; border-radius: 8rpx; background: #f0f0f0; color: #999; }
.confirm-toggle.on { background: #e8f5e9; color: #1aad19; font-weight: 600; }
.tag-draft { background: #fff3e0; color: #e65100; font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; }

.empty-state { padding: 80rpx 0; text-align: center; font-size: 28rpx; color: #bbb; }
.btn-area { padding: 24rpx; }

.poster-placeholder { font-size: 32rpx; color: #ccc; white-space: nowrap; }
.poster-upload { margin-top: 8rpx; min-width: 240rpx; height: 120rpx; border-radius: 12rpx; overflow: hidden; background: #f7f7f7; display: flex; align-items: center; justify-content: center; border: 2rpx dashed #ddd; }
.poster-preview { width: 100%; height: 100%; }
.poster-placeholder { font-size: 48rpx; color: #ccc; }

.btn-row.wrap { flex-wrap: wrap; }

.timeline-form { display: flex; align-items: center; margin-top: 8rpx; }
.tl-label { font-size: 24rpx; color: #666; width: 120rpx; flex-shrink: 0; }
.tl-pickers { flex: 1; display: flex; gap: 8rpx; align-items: center; }
.tl-date-pick { background: #f7f7f7; border-radius: 8rpx; padding: 12rpx 16rpx; font-size: 26rpx; flex: 2; }
.tl-time-pick { flex: 1; text-align: center; }
.tl-clear { font-size: 28rpx; color: #ccc; padding: 4rpx; flex-shrink: 0; }

.gun-block { background: #f9f9f9; border-radius: 12rpx; padding: 16rpx; margin: 8rpx 0; }
.gun-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 8rpx; }
.gun-zone-input { font-size: 24rpx; padding: 10rpx 12rpx; background: #fff; border-radius: 8rpx; color: #333; width: 100rpx; text-align: center; }
.gun-time-pick { font-size: 24rpx; padding: 10rpx 16rpx; background: #fff; border-radius: 8rpx; color: #333; }
.gun-del { font-size: 28rpx; padding: 4rpx; color: #ff4d4f; }
.add-guntime { text-align: center; padding: 10rpx; font-size: 24rpx; color: #1aad19; border: 1rpx dashed #1aad19; border-radius: 8rpx; }
