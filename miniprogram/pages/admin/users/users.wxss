/* pages/admin/users/users.wxss */
.user-card-item { padding: 24rpx 28rpx; }
.user-row { display: flex; align-items: center; }
.u-avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: #f0f0f0; flex-shrink: 0;
}
.u-info { flex: 1; margin-left: 20rpx; }
.u-name { font-size: 28rpx; font-weight: 600; display: block; }
.u-meta { font-size: 24rpx; color: #999; display: block; margin-top: 4rpx; }
.u-tags { display: flex; gap: 8rpx; }

.u-actions { display: flex; justify-content: flex-end; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; }
.btn-remove {
  background: #fff; color: #ff4d4f; border: 2rpx solid #ff4d4f;
  border-radius: 8rpx; padding: 10rpx 28rpx; font-size: 24rpx;
}
