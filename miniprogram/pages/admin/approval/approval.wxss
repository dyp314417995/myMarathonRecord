/* pages/admin/approval/approval.wxss */
.request-card { padding: 28rpx 32rpx; }
.req-header { display: flex; align-items: center; }
.req-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: #f0f0f0; flex-shrink: 0; border: 2rpx solid #1aad19;
}
.req-info { flex: 1; margin-left: 20rpx; }
.req-name { font-size: 30rpx; font-weight: 600; display: block; }
.req-meta { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.req-time { font-size: 24rpx; color: #bbb; margin-top: 16rpx; }

.req-actions { display: flex; gap: 16rpx; margin-top: 20rpx; justify-content: flex-end; }
.btn-approve {
  background: #1aad19; color: #fff; border: none;
  border-radius: 10rpx; padding: 14rpx 32rpx; font-size: 26rpx;
}
.btn-reject {
  background: #fff; color: #ff4d4f; border: 2rpx solid #ff4d4f;
  border-radius: 10rpx; padding: 14rpx 32rpx; font-size: 26rpx;
}

/* 详情弹窗 */
.modal-mask { position: fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:100; }
.modal-box { position:fixed; top:15%; left:32rpx; right:32rpx; background:#fff; border-radius:20rpx; padding:32rpx; z-index:101; max-height:75%; overflow-y:auto; }
.detail-header { display:flex; flex-direction:column; align-items:center; margin-bottom:24rpx; }
.detail-avatar { width:120rpx; height:120rpx; border-radius:50%; background:#f0f0f0; }
.detail-name { font-size:32rpx; font-weight:600; margin-top:12rpx; }
.info-row { display:flex; justify-content:space-between; padding:16rpx 0; border-bottom:1rpx solid #f7f7f7; }
.info-label { font-size:26rpx; color:#999; }
.info-value { font-size:26rpx; color:#333; }
