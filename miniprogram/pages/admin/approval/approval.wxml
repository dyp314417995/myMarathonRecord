<!-- pages/admin/approval/approval.wxml - 审批列表 -->
<view class="approval-page">
  <block wx:if="{{!loading && requests.length === 0}}">
    <view class="empty-state">
      <text>暂无待审批申请</text>
    </view>
  </block>

  <block wx:for="{{requests}}" wx:key="_id">
    <view class="card request-card">
      <view class="req-header">
        <image class="req-avatar" src="{{item.userAvatar || '/imgs/back.svg'}}" mode="aspectFill" data-id="{{item.userId}}" catchtap="onViewDetail" />
        <view class="req-info">
          <text class="req-name">{{item.userName}}</text>
          <text class="req-meta">{{item.userCity || '未知城市'}} · 申请加入 {{item.groupName}}</text>
        </view>
        <text class="tag tag-orange">待审批</text>
      </view>
      <view class="req-time">申请时间：{{item.createTime}}</view>
      <view class="req-actions">
        <button class="btn-reject" data-id="{{item._id}}" data-user-id="{{item.userId}}" bindtap="onReject">拒绝</button>
        <button class="btn-approve" data-id="{{item._id}}" data-user-id="{{item.userId}}" data-group-id="{{item.groupId}}" bindtap="onApprove">通过</button>
      </view>
    </view>
  </block>
</view>

<!-- 用户详情弹窗 -->
<view class="modal-mask" wx:if="{{showDetail}}" catchtap="onHideDetail"></view>
<view class="modal-box" wx:if="{{showDetail}}" catchtap="">
  <view class="detail-header">
    <image class="detail-avatar" src="{{detailUser.avatarUrl || '/imgs/back.svg'}}" mode="aspectFill" />
    <text class="detail-name">{{detailUser.nickName || '未知'}}</text>
  </view>
  <view class="info-row"><text class="info-label">城市</text><text class="info-value">{{detailUser.city || '-'}}</text></view>
  <view class="info-row"><text class="info-label">10K PB</text><text class="info-value">{{detailUser.pb10k || '-'}}</text></view>
  <view class="info-row"><text class="info-label">半马 PB</text><text class="info-value">{{detailUser.pbHalf || '-'}}</text></view>
  <view class="info-row"><text class="info-label">全马 PB</text><text class="info-value">{{detailUser.pbFull || '-'}}</text></view>
  <button class="btn-outline" bindtap="onHideDetail" style="margin-top:24rpx;">关闭</button>
</view>
