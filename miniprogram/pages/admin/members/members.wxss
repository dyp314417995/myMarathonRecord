/* pages/admin/members/members.wxss - 跑友名录 */
.toolbar {
  padding: 16rpx 24rpx; background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}
.search-input {
  height: 72rpx; background: #f7f7f7; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; margin-bottom: 12rpx;
}
.sort-row { display: flex; gap: 12rpx; align-items: center; margin-bottom: 8rpx; flex-wrap: wrap; }
.sort-item {
  padding: 12rpx 20rpx; border-radius: 8rpx;
  background: #f5f5f5; font-size: 24rpx; color: #666;
}
.sort-item.active { background: #e8f5e9; color: #1aad19; font-weight: 600; }
.total-count { font-size: 22rpx; color: #bbb; }

.user-card-item { padding: 20rpx 24rpx; margin: 8rpx 12rpx; }
.user-row { display: flex; align-items: flex-start; }
.u-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: #f0f0f0; flex-shrink: 0; }
.u-info { flex: 1; margin-left: 20rpx; }
.u-name { font-size: 28rpx; font-weight: 600; display: block; }
.u-meta { font-size: 24rpx; color: #999; display: block; margin-top: 2rpx; }
.u-pb { font-size: 22rpx; color: #1aad19; display: block; margin-top: 4rpx; }
.u-tags { display: flex; gap: 8rpx; flex-shrink: 0; }

/* 详情弹窗 */
.modal-mask { position: fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:100; }
.modal-box { position:fixed; top:15%; left:32rpx; right:32rpx; background:#fff; border-radius:20rpx; padding:32rpx; z-index:101; max-height:75%; overflow-y:auto; }
.detail-header { display:flex; flex-direction:column; align-items:center; margin-bottom:24rpx; }
.detail-avatar { width:120rpx; height:120rpx; border-radius:50%; background:#f0f0f0; }
.detail-name { font-size:32rpx; font-weight:600; margin-top:12rpx; }
.info-row { display:flex; justify-content:space-between; padding:16rpx 0; border-bottom:1rpx solid #f7f7f7; }
.info-label { font-size:26rpx; color:#999; }
.info-value { font-size:26rpx; color:#333; }

.empty-state { text-align: center; padding: 80rpx 0; color: #ccc; font-size: 28rpx; }

.load-more { text-align: center; padding: 32rpx; color: #1aad19; font-size: 28rpx; }

.info-divider { padding: 24rpx 0 12rpx; font-size: 26rpx; color: #1aad19; font-weight: 500; text-align: center; }
.race-item { padding: 12rpx 0; border-bottom: 1rpx solid #f7f7f7; }
.race-type { font-size: 24rpx; color: #333; display: block; }
.race-meta { font-size: 22rpx; color: #999; display: block; margin-top: 2rpx; }
.race-result { font-size: 26rpx; color: #ff6b00; font-weight: bold; display: block; margin-top: 4rpx; }
