<!-- pages/records/public.wxml - 只读跑马记录 -->
<view class="records-page">
  <view class="tabs">
    <text class="tab {{tab === 'half' ? 'active' : ''}}" data-t="half" bindtap="onTab">半马</text>
    <text class="tab {{tab === 'full' ? 'active' : ''}}" data-t="full" bindtap="onTab">全马</text>
    <text class="tab {{tab === '10k' ? 'active' : ''}}" data-t="10k" bindtap="onTab">10K</text>
    <text class="tab {{tab === 'trail' ? 'active' : ''}}" data-t="trail" bindtap="onTab">越野</text>
  </view>

  <view wx:if="{{showChart}}" class="chart-panel">
    <text class="chart-title">📈 成绩变化</text>
    <view class="chart-box">
      <view wx:for="{{chartData}}" wx:key="date" class="chart-row">
        <view class="chart-label">
          <text class="chart-date">{{item.date}}</text>
          <text class="chart-city">{{item.city}}</text>
        </view>
        <view class="chart-bar-wrap">
          <view class="chart-bar {{item.isPB ? 'pb' : ''}}" style="width: {{item.width}}%">
            <text class="chart-bar-text">{{item.result}}</text>
          </view>
        </view>
        <text class="chart-badge" wx:if="{{item.isPB}}">🏆PB</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="list" wx:if="{{filteredRecords.length > 0}}">
    <block wx:for="{{filteredRecords}}" wx:key="_id">
      <view class="card">
        <view class="card-header">
          <view wx:if="{{item.raceType === 'trail' && item.certs}}" class="cert-tags">
            <text class="tag cert-tag" wx:for="{{item.certs.itra ? ['ITRA'] : []}}" wx:key="*this">ITRA</text>
            <text class="tag cert-tag" wx:for="{{item.certs.utmb ? ['UTMB'] : []}}" wx:key="*this">UTMB</text>
            <text class="tag cert-tag" wx:for="{{item.certs.utmbws ? ['UTMB WS'] : []}}" wx:key="*this">UTMB WS</text>
          </view>
          <text wx:else class="level-tag {{item.raceLevel}}">{{item.raceLevel === 'A' ? '🅰' : item.raceLevel === 'B' ? '🅱' : '🅲'}}</text>
          <text class="type-text">{{item.raceType === '10k' ? '10公里' : item.raceType === 'half' ? '半程马拉松' : item.raceType === 'trail' ? '越野跑' : '全程马拉松'}}</text>
          <text class="status-tag {{item.status}}">{{item.status === 'planned' ? '计划报名' : item.status === 'finished' ? '已完赛' : item.status === 'dnf' ? '未完赛' : item.status === 'dns' ? '弃赛' : item.status === 'won' ? '已中签' : '已报名'}}</text>
        </view>
        <view class="card-body">
          <view class="card-row"><text class="label">赛事</text><text class="value">{{item.city || '未知'}}{{item.date ? ' · ' + item.date : ''}}</text></view>
          <view class="card-row" wx:if="{{item.raceType === 'trail' && (item.distance || item.elevation)}}">
            <text class="label">路线</text>
            <text class="value">{{item.distance ? item.distance + 'km' : ''}}{{item.distance && item.elevation ? ' · 爬升' + item.elevation + 'm' : ''}}{{item.elevation && !item.distance ? '爬升' + item.elevation + 'm' : ''}}</text>
          </view>
          <view class="card-row" wx:if="{{item.raceType === 'trail' && item.status === 'finished' && item.itra}}">
            <text class="label">ITRA</text>
            <text class="value itra-score">{{item.itra}}分</text>
          </view>
          <view class="card-row" wx:if="{{item.status === 'finished' && item.result}}"><text class="label">成绩</text><text class="value result">{{item.result}} <text class="pb-badge" wx:if="{{item.isPB}}">🏆PB</text></text></view>
          <view class="card-row" wx:if="{{item.note}}"><text class="value note">"{{item.note}}"</text></view>
        </view>
        <view wx:if="{{item.imgUrls.length > 0}}" class="card-imgs">
          <image wx:for="{{item.imgUrls}}" wx:key="*this" src="{{item}}" mode="aspectFill" class="card-img" bindtap="onImagePreview" data-src="{{item}}" />
        </view>
      </view>
    </block>
  </scroll-view>

  <view class="empty" wx:if="{{filteredRecords.length === 0}}">
    <text class="empty-text">暂无 {{tab === '10k' ? '10K' : tab === 'half' ? '半马' : tab === 'trail' ? '越野跑' : '全马'}} 记录</text>
  </view>
</view>
