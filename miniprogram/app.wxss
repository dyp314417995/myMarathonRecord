/* 全局样式 - 我的跑马记录 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: #f5f5f5;
  color: #333;
  font-size: 28rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #1aad19, #0d8c0d);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
}
.btn-primary:active { opacity: 0.85; }

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  text-align: center;
}

.btn-outline {
  background: #fff;
  color: #1aad19;
  border: 2rpx solid #1aad19;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  text-align: center;
}

/* 表单 */
.form-group {
  margin-bottom: 32rpx;
}
.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}
.form-input {
  width: 100%;
  height: auto;
  padding: 24rpx 20rpx;
  background: #f7f7f7;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 标签/徽章 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-green { background: #e8f5e9; color: #1aad19; }
.tag-orange { background: #fff3e0; color: #ff9800; }
.tag-red { background: #ffebee; color: #f44336; }
.tag-blue { background: #e3f2fd; color: #2196f3; }
.tag-gray { background: #f5f5f5; color: #999; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.empty-state text { color: #999; font-size: 28rpx; margin-top: 24rpx; }

/* 分隔线 */
.divider {
  height: 1rpx;
  background: #eee;
  margin: 24rpx 0;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.list-item:last-child { border-bottom: none; }

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: #1aad19;
}
